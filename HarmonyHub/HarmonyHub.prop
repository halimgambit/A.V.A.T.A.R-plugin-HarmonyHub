{
	"modules": { 
		"HarmonyHub": {
			"version": "1.0",
			"name": "Harmonyhub",
			"ip": "192.168.1.1XX",
			"rules": {
				"startTV": ["turn on the tv"],
				"startPS": ["turn on the playstation"],
				"powerOff": ["turn off the tv"],
				"currentActivity": ["activities"],
				"startNetflix": ["netflix"]
			}
		}
	}
}
			
